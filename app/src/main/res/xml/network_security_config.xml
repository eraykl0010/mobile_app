<?xml version="1.0" encoding="utf-8"?>
<!--
    Ağ Güvenlik Yapılandırması
    ==========================
    • Varsayılan: Tüm bağlantılar HTTPS zorunlu (cleartextTrafficPermitted="false")
    • İstisna: Yalnızca localhost ve Android emulator adresleri HTTP'ye izin verir
      (geliştirme sırasında yerel sunucuya bağlanmak için)
    • Production API (onlinepdks.com.tr) zaten HTTPS — bu yapılandırma onu korur
-->
<network-security-config>

    <!-- Varsayılan: tüm domainler için HTTPS zorunlu -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Geliştirme ortamı istisnaları — sadece localhost -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>

</network-security-config>