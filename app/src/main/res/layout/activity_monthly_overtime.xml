<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <include layout="@layout/layout_toolbar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md">

            <!-- Ay Seçici -->
            <Spinner
                android:id="@+id/spinnerMonth"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:background="@drawable/bg_edit_text"
                android:paddingStart="@dimen/spacing_sm"
                android:layout_marginBottom="@dimen/spacing_md" />

            <ProgressBar
                android:id="@+id/progressOvertime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:indeterminateTint="@color/primary"
                android:visibility="gone" />

            <!-- Özet Kartı -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardOvertimeSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/card_radius"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Aylık Mesai Özeti"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_subtitle"
                        android:textStyle="bold"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <!-- İstatistik Grid -->
                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:rowCount="3">

                        <!-- Toplam Çalışma -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_margin="4dp"
                            android:background="@drawable/bg_card_rounded"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="@dimen/spacing_md">

                            <TextView
                                android:id="@+id/tvTotalWorkHours"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/primary"
                                android:textSize="@dimen/text_large_number"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Toplam Saat"
                                android:textColor="@color/text_secondary"
                                android:textSize="@dimen/text_caption" />
                        </LinearLayout>

                        <!-- Mesai -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_margin="4dp"
                            android:background="@drawable/bg_card_rounded"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="@dimen/spacing_md">

                            <TextView
                                android:id="@+id/tvOvertimeHours"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/accent"
                                android:textSize="@dimen/text_large_number"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Mesai Saat"
                                android:textColor="@color/text_secondary"
                                android:textSize="@dimen/text_caption" />
                        </LinearLayout>

                        <!-- İş Günü -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_margin="4dp"
                            android:background="@drawable/bg_card_rounded"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="@dimen/spacing_md">

                            <TextView
                                android:id="@+id/tvWorkDays"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/status_success"
                                android:textSize="@dimen/text_large_number"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="İş Günü"
                                android:textColor="@color/text_secondary"
                                android:textSize="@dimen/text_caption" />
                        </LinearLayout>

                        <!-- Devamsızlık -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_margin="4dp"
                            android:background="@drawable/bg_card_rounded"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="@dimen/spacing_md">

                            <TextView
                                android:id="@+id/tvAbsentDays"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/status_danger"
                                android:textSize="@dimen/text_large_number"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Devamsız"
                                android:textColor="@color/text_secondary"
                                android:textSize="@dimen/text_caption" />
                        </LinearLayout>

                        <!-- Geç Gelme -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_margin="4dp"
                            android:background="@drawable/bg_card_rounded"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="@dimen/spacing_md">

                            <TextView
                                android:id="@+id/tvMonthLateCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/status_warning"
                                android:textSize="@dimen/text_large_number"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Geç Gelme"
                                android:textColor="@color/text_secondary"
                                android:textSize="@dimen/text_caption" />
                        </LinearLayout>

                        <!-- Erken Çıkma -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_margin="4dp"
                            android:background="@drawable/bg_card_rounded"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="@dimen/spacing_md">

                            <TextView
                                android:id="@+id/tvMonthEarlyCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#FF7043"
                                android:textSize="@dimen/text_large_number"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Erken Çıkma"
                                android:textColor="@color/text_secondary"
                                android:textSize="@dimen/text_caption" />
                        </LinearLayout>
                    </GridLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>
</LinearLayout>