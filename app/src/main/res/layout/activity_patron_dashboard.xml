<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Üst Bar -->
    <LinearLayout
        android:id="@+id/toolbarWrapper"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:id="@+id/statusBarSpacer"
            android:layout_width="match_parent"
            android:layout_height="0dp" />

        <LinearLayout
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/toolbar_height"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="@dimen/spacing_md"
            android:paddingEnd="@dimen/spacing_md">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Patron Paneli"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/btnLogout"
                android:layout_width="@dimen/icon_size_md"
                android:layout_height="@dimen/icon_size_md"
                android:padding="6dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="@color/white"
                android:contentDescription="Çıkış"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>
    </LinearLayout>

    <!-- Hoşgeldin Mesajı -->
    <TextView
        android:id="@+id/tvWelcome"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Hoş geldiniz"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_subtitle"
        android:textStyle="bold"
        android:padding="@dimen/spacing_md"
        app:layout_constraintTop_toBottomOf="@id/toolbarWrapper"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/tvWelcome"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/spacing_md"
            android:paddingEnd="@dimen/spacing_md"
            android:paddingBottom="@dimen/spacing_lg">

            <!-- ═══════ MENÜ 1: Personel Bilgi Kartı ═══════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPersonnelInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="@dimen/card_radius"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white"
                app:rippleColor="#22FF6D00">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <!-- Başlık Satırı -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="24dp"
                            android:background="@color/primary" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="@dimen/spacing_sm"
                            android:text="Personel Bilgi Kartı"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_subtitle"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/iconExpandPersonnel"
                            android:layout_width="@dimen/icon_size_sm"
                            android:layout_height="@dimen/icon_size_sm"
                            android:src="@android:drawable/arrow_down_float"
                            app:tint="@color/text_secondary"
                            android:contentDescription="Aç/Kapat" />
                    </LinearLayout>

                    <!-- Özet: 2 satır, 3'er kutu -->
                    <GridLayout
                        android:id="@+id/gridSummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:columnCount="3"
                        android:rowCount="2">
                        <!-- Mevcut -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_margin="4dp"
                            android:background="@drawable/bg_card_rounded"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="@dimen/spacing_sm">

                            <TextView
                                android:id="@+id/tvTotalCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/status_info"
                                android:textSize="@dimen/text_large_number"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Mevcut"
                                android:textColor="@color/text_secondary"
                                android:textSize="@dimen/text_caption" />
                        </LinearLayout>
                        <!-- Aktif -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_margin="4dp"
                            android:background="@drawable/bg_card_rounded"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="@dimen/spacing_sm">

                            <TextView
                                android:id="@+id/tvActiveCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/status_success"
                                android:textSize="@dimen/text_large_number"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Aktif"
                                android:textColor="@color/text_secondary"
                                android:textSize="@dimen/text_caption" />
                        </LinearLayout>

                        <!-- İzinli -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_margin="4dp"
                            android:background="@drawable/bg_card_rounded"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="@dimen/spacing_sm">

                            <TextView
                                android:id="@+id/tvOnLeaveCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/accent"
                                android:textSize="@dimen/text_large_number"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="İzinli"
                                android:textColor="@color/text_secondary"
                                android:textSize="@dimen/text_caption" />
                        </LinearLayout>

                        <!-- Devamsız -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_margin="4dp"
                            android:background="@drawable/bg_card_rounded"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="@dimen/spacing_sm">

                            <TextView
                                android:id="@+id/tvAbsentCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/status_danger"
                                android:textSize="@dimen/text_large_number"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Devamsız"
                                android:textColor="@color/text_secondary"
                                android:textSize="@dimen/text_caption" />
                        </LinearLayout>

                        <!-- Geç Gelen -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_margin="4dp"
                            android:background="@drawable/bg_card_rounded"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="@dimen/spacing_sm">

                            <TextView
                                android:id="@+id/tvLateCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/status_warning"
                                android:textSize="@dimen/text_large_number"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Geç Gelen"
                                android:textColor="@color/text_secondary"
                                android:textSize="@dimen/text_caption" />
                        </LinearLayout>

                        <!-- Erken Çıkan -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_margin="4dp"
                            android:background="@drawable/bg_card_rounded"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="@dimen/spacing_sm">

                            <TextView
                                android:id="@+id/tvEarlyLeaveCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#FF7043"
                                android:textSize="@dimen/text_large_number"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Erken Çıkan"
                                android:textColor="@color/text_secondary"
                                android:textSize="@dimen/text_caption" />
                        </LinearLayout>
                    </GridLayout>

                    <!-- Departman Filtre -->
                    <Spinner
                        android:id="@+id/spinnerDepartment"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:background="@drawable/bg_edit_text"
                        android:paddingStart="@dimen/spacing_sm"
                        android:paddingEnd="@dimen/spacing_sm" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══════ MENÜ 2: Onay Ekranı ═══════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardApprovals"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="@dimen/card_radius"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white"
                app:rippleColor="#22FF6D00">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="24dp"
                            android:background="@color/accent" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="@dimen/spacing_sm"
                            android:text="Onay Bekleyenler"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_subtitle"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- 4 Alt Menü: 2x2 Grid -->
                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:columnCount="2"
                        android:rowCount="2">

                        <!-- Yıllık İzin -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardAnnualLeave"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_margin="4dp"
                            android:clickable="true"
                            android:focusable="true"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="1dp"
                            app:cardBackgroundColor="@color/primary_very_light"
                            app:rippleColor="#22FF6D00">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="@dimen/spacing_sm">
                                <TextView
                                    android:id="@+id/tvAnnualLeaveCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textColor="@color/primary"
                                    android:textSize="22sp"
                                    android:textStyle="bold" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Yıllık İzin"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="11sp"
                                    android:gravity="center" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Günlük İzin -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardDailyLeave"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_margin="4dp"
                            android:clickable="true"
                            android:focusable="true"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="1dp"
                            app:cardBackgroundColor="@color/primary_very_light"
                            app:rippleColor="#22FF6D00">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="@dimen/spacing_sm">
                                <TextView
                                    android:id="@+id/tvDailyLeaveCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textColor="@color/primary"
                                    android:textSize="22sp"
                                    android:textStyle="bold" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Günlük İzin"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="11sp"
                                    android:gravity="center" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Saatlik İzin -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardHourlyLeave"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_margin="4dp"
                            android:clickable="true"
                            android:focusable="true"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="1dp"
                            app:cardBackgroundColor="@color/primary_very_light"
                            app:rippleColor="#22FF6D00">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="@dimen/spacing_sm">
                                <TextView
                                    android:id="@+id/tvHourlyLeaveCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textColor="@color/primary"
                                    android:textSize="22sp"
                                    android:textStyle="bold" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Saatlik İzin"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="11sp"
                                    android:gravity="center" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Avans -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardAdvance"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_margin="4dp"
                            android:clickable="true"
                            android:focusable="true"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="1dp"
                            app:cardBackgroundColor="@color/primary_very_light"
                            app:rippleColor="#22FF6D00">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="@dimen/spacing_sm">
                                <TextView
                                    android:id="@+id/tvAdvanceCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textColor="@color/primary"
                                    android:textSize="22sp"
                                    android:textStyle="bold" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Avans"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="11sp"
                                    android:gravity="center" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </GridLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══════ MENÜ 3: Geç Gelen / Erken Çıkan ═══════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLateEarly"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="@dimen/card_radius"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white"
                app:rippleColor="#22FF6D00">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="24dp"
                            android:background="@color/status_warning" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="@dimen/spacing_sm"
                            android:text="Dünkü Fazla Mesai / Eksik Mesai"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_subtitle"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:background="@drawable/bg_card_rounded"
                            android:padding="@dimen/spacing_sm"
                            android:layout_marginEnd="@dimen/spacing_xs">

                            <TextView
                                android:id="@+id/tvOvertimeCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/status_success"
                                android:textSize="22sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Fazla Mesai"
                                android:textColor="@color/text_secondary"
                                android:textSize="@dimen/text_caption" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:background="@drawable/bg_card_rounded"
                            android:padding="@dimen/spacing_sm"
                            android:layout_marginStart="@dimen/spacing_xs">

                            <TextView
                                android:id="@+id/tvUndertimeCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#FF7043"
                                android:textSize="22sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Eksik Mesai"
                                android:textColor="@color/text_secondary"
                                android:textSize="@dimen/text_caption" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Detaylar için dokunun →"
                        android:textColor="@color/primary"
                        android:textSize="@dimen/text_caption"
                        android:layout_marginTop="@dimen/spacing_sm" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>