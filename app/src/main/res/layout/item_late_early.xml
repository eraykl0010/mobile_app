<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_sm"
    app:cardCornerRadius="12dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_md"
        android:gravity="center_vertical">

        <!-- Tür İndikatörü -->
        <TextView
            android:id="@+id/tvTypeBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_gradient_orange"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="GEÇ"
            android:textColor="@color/white"
            android:textSize="10sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="@dimen/spacing_sm">

            <TextView
                android:id="@+id/tvLeName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ad Soyad"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_body"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvLeDepartment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Departman"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_caption" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tvLeTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="08:45"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_body"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvLeDiff"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+15 dk"
                android:textColor="@color/status_danger"
                android:textSize="@dimen/text_caption" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>