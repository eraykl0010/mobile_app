<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefreshPersonnelDetail"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/background">

    <include layout="@layout/layout_toolbar" />

    <!-- Departman Filtre -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_md"
        android:background="@color/white"
        android:elevation="2dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Departman: "
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_body" />

        <Spinner
            android:id="@+id/spinnerDetailDept"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/bg_edit_text"
            android:paddingStart="@dimen/spacing_sm"
            android:paddingEnd="@dimen/spacing_sm" />
    </LinearLayout>

    <!-- Özet Grid — Tıklanabilir -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/spacing_md"
        app:cardCornerRadius="@dimen/card_radius"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/white">

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/spacing_sm"
            android:columnCount="3"
            android:rowCount="2">
            <!-- Mevcut -->
            <LinearLayout
                android:id="@+id/boxTotal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/bg_card_rounded"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/spacing_sm"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:id="@+id/tvDetTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/status_info"
                    android:textSize="@dimen/text_large_number"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mevcut Personel"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Aktif -->
            <LinearLayout
                android:id="@+id/boxActive"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/bg_card_rounded"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/spacing_sm"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:id="@+id/tvDetActive"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/status_success"
                    android:textSize="@dimen/text_large_number"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Aktif Çalışan"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:gravity="center" />
            </LinearLayout>

            <!-- İzinli -->
            <LinearLayout
                android:id="@+id/boxLeave"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/bg_card_rounded"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/spacing_sm"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:id="@+id/tvDetLeave"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/accent"
                    android:textSize="@dimen/text_large_number"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="İzinli"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Devamsız -->
            <LinearLayout
                android:id="@+id/boxAbsent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/bg_card_rounded"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/spacing_sm"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:id="@+id/tvDetAbsent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/status_danger"
                    android:textSize="@dimen/text_large_number"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Devamsız"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Geç Gelen -->
            <LinearLayout
                android:id="@+id/boxLate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/bg_card_rounded"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/spacing_sm"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:id="@+id/tvDetLate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/status_warning"
                    android:textSize="@dimen/text_large_number"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                        android:text="Geç Kalan"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Erken Çıkan -->
            <LinearLayout
                android:id="@+id/boxEarly"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/bg_card_rounded"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/spacing_sm"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:id="@+id/tvDetEarly"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FF7043"
                    android:textSize="@dimen/text_large_number"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Erken Çıkan"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:gravity="center" />
            </LinearLayout>
        </GridLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Aktif Filtre Göstergesi -->
    <LinearLayout
        android:id="@+id/layoutActiveFilter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/spacing_md"
        android:paddingEnd="@dimen/spacing_md"
        android:paddingBottom="@dimen/spacing_sm"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvActiveFilter"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Filtre: Aktif Çalışanlar"
            android:textColor="@color/primary"
            android:textSize="@dimen/text_caption"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnClearFilter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✕ Temizle"
            android:textColor="@color/status_danger"
            android:textSize="@dimen/text_caption"
            android:textStyle="bold"
            android:padding="@dimen/spacing_sm"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- Liste Başlığı -->
    <TextView
        android:id="@+id/tvListTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Personel Listesi"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_subtitle"
        android:textStyle="bold"
        android:paddingStart="@dimen/spacing_md"
        android:paddingBottom="@dimen/spacing_sm" />

    <ProgressBar
        android:id="@+id/progressDetail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminateTint="@color/primary"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPersonnelList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="@dimen/spacing_sm"
        android:clipToPadding="false" />

    </LinearLayout>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>