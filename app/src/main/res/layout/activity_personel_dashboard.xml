<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Üst Bar -->
    <LinearLayout
        android:id="@+id/toolbarWrapper"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:id="@+id/statusBarSpacer"
            android:layout_width="match_parent"
            android:layout_height="0dp" />

        <LinearLayout
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/toolbar_height"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="@dimen/spacing_md"
            android:paddingEnd="@dimen/spacing_md">

            <TextView
                android:id="@+id/tvToolbarTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Personel Paneli"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Hoşgeldin -->
    <TextView
        android:id="@+id/tvWelcomePersonel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Hoş geldiniz"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_subtitle"
        android:textStyle="bold"
        android:padding="@dimen/spacing_md"
        app:layout_constraintTop_toBottomOf="@id/toolbarWrapper"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/tvWelcomePersonel"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/spacing_md"
            android:paddingEnd="@dimen/spacing_md"
            android:paddingBottom="@dimen/spacing_lg">

            <!-- ═══ GİRİŞ-ÇIKIŞ BUTONLARI ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/spacing_sm">

                <!-- Konum ile Giriş/Çıkış -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardLocationCheckIn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/spacing_xs"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="@dimen/card_radius"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/primary"
                    app:rippleColor="#33FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_md">

                        <ImageView
                            android:layout_width="@dimen/icon_size_lg"
                            android:layout_height="@dimen/icon_size_lg"
                            android:src="@android:drawable/ic_menu_mylocation"
                            app:tint="@color/white"
                            android:contentDescription="Konum" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Konum ile\nGiriş/Çıkış"
                            android:textColor="@color/white"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:layout_marginTop="@dimen/spacing_sm" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- QR + Konum ile Giriş/Çıkış -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardQrCheckIn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/spacing_xs"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="@dimen/card_radius"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/primary_dark"
                    app:rippleColor="#33FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_md">

                        <ImageView
                            android:layout_width="@dimen/icon_size_lg"
                            android:layout_height="@dimen/icon_size_lg"
                            android:src="@android:drawable/ic_menu_camera"
                            app:tint="@color/white"
                            android:contentDescription="QR" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="QR + Konum\nGiriş/Çıkış"
                            android:textColor="@color/white"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:layout_marginTop="@dimen/spacing_sm" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- ═══ GÜNLÜK/HAFTALIK RAPOR ═══ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAttendanceReport"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="@dimen/card_radius"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white"
                app:rippleColor="#22FF6D00">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_md"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="40dp"
                        android:background="@color/status_info" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="@dimen/spacing_sm">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Giriş-Çıkış Raporu"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_subtitle"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Günlük ve haftalık giriş-çıkış bilgileri"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_caption" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="@dimen/icon_size_sm"
                        android:layout_height="@dimen/icon_size_sm"
                        android:src="@android:drawable/ic_media_play"
                        app:tint="@color/primary"
                        android:contentDescription="Git" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══ İZİN TALEBİ ═══ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLeaveRequest"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="@dimen/card_radius"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white"
                app:rippleColor="#22FF6D00">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_md"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="40dp"
                        android:background="@color/status_success" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="@dimen/spacing_sm">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="İzin Talebi"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_subtitle"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="İzin talebi oluştur ve sonuçları görüntüle"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_caption" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="@dimen/icon_size_sm"
                        android:layout_height="@dimen/icon_size_sm"
                        android:src="@android:drawable/ic_media_play"
                        app:tint="@color/primary"
                        android:contentDescription="Git" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══ AVANS TALEBİ ═══ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAdvanceRequest"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="@dimen/card_radius"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white"
                app:rippleColor="#22FF6D00">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_md"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="40dp"
                        android:background="@color/accent" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="@dimen/spacing_sm">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Avans Talebi"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_subtitle"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Avans talebi oluştur ve sonuçları görüntüle"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_caption" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="@dimen/icon_size_sm"
                        android:layout_height="@dimen/icon_size_sm"
                        android:src="@android:drawable/ic_media_play"
                        app:tint="@color/primary"
                        android:contentDescription="Git" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══ AYLIK MESAİ ═══ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMonthlyOvertime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="@dimen/card_radius"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white"
                app:rippleColor="#22FF6D00">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_md"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="40dp"
                        android:background="@color/status_warning" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="@dimen/spacing_sm">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Aylık Mesai Bilgisi"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_subtitle"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Aylık toplam çalışma ve mesai saatleri"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_caption" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="@dimen/icon_size_sm"
                        android:layout_height="@dimen/icon_size_sm"
                        android:src="@android:drawable/ic_media_play"
                        app:tint="@color/primary"
                        android:contentDescription="Git" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>