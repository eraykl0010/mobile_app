<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_xs"
    app:cardCornerRadius="12dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_md"
        android:gravity="center_vertical">

        <!-- Durum İndikatörü -->
        <View
            android:id="@+id/viewStatusIndicator"
            android:layout_width="6dp"
            android:layout_height="40dp"
            android:background="@color/status_success" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="@dimen/spacing_sm">

            <TextView
                android:id="@+id/tvPersName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ad Soyad"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_body"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvPersDept"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Departman"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_caption" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tvPersCheckIn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="G: 08:30"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_caption" />

            <TextView
                android:id="@+id/tvPersCheckOut"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ç: --:--"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_caption" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvPersStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:layout_marginStart="@dimen/spacing_sm"
            android:text="Aktif"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>