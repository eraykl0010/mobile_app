<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_sm"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvAdvPersonnelName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Ad Soyad"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_subtitle"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvAdvAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₺5.000"
                android:textColor="@color/primary"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvAdvDepartment"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Departman"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_caption"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/tvAdvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Talep: 01.01.2025"
            android:textColor="@color/text_hint"
            android:textSize="@dimen/text_caption"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvAdvReason"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Açıklama"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_caption"
            android:layout_marginTop="@dimen/spacing_sm"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:gravity="end"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnAdvReject"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:background="@drawable/bg_edit_text"
                android:paddingStart="@dimen/spacing_md"
                android:paddingEnd="@dimen/spacing_md"
                android:text="REDDET"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:stateListAnimator="@null"
                android:layout_marginEnd="@dimen/spacing_sm" />

            <Button
                android:id="@+id/btnAdvApprove"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:background="@drawable/bg_button_primary"
                android:paddingStart="@dimen/spacing_md"
                android:paddingEnd="@dimen/spacing_md"
                android:text="ONAYLA"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:stateListAnimator="@null" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>